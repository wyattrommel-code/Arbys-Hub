# Copy to .env.local for local dev and set the same in Vercel → Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PIN login session signing (generate a random 32+ char string)
SESSION_SECRET=

# Supabase Dashboard → Project Settings → API → service_role (secret key)
SUPABASE_SERVICE_ROLE_KEY=
